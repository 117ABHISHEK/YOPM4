# ========================
# Node.js dependencies
# ========================
node_modules/

# ========================
# Logs
# ========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ========================
# Build output
# ========================
dist/
build/
.cache/
.next/
out/

# ========================
# OS generated files
# ========================
.DS_Store
Thumbs.db

# ========================
# Environment files (DO NOT COMMIT SECRETS)
# ========================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ========================
# IDE / Editor settings
# ========================
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# ========================
# Miscellaneous
# ========================
*.bak
*.tmp
*.swp
*.lock-wscript

# ========================
# Databases / sensitive files
# ========================
*.sqlite
*.db
*.db-journal

# ========================
# Frontend cache / build
# ========================
public/*.map
*.tsbuildinfo

# ========================
# Optional - skip OS trash
# ========================
.trash/
